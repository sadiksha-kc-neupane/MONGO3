<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chats</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>All Chats</h1>
    <% chats.forEach(chat => { %>
        <div class="chat">
            <p><strong>From : <%= chat.from %></strong> 
            <p> To :<%= chat.to %>  </p>
            <div class="message">
            <p> Message: <%= chat.message %></p>
            </div>
            
            <small>Time : </time><%= chat.createdAt %>
            </small>
        </div>
     
    </hr>
    <% }) %>
</body>
</html>